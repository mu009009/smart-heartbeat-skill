{
  "version": "1.0.0",
  "description": "Smart Heartbeat Skill Configuration - User Behavior Driven Reminder System",
  "last_updated": "2026-03-09",
  
  "reminder_strategy": "user_behavior_driven",
  "skill_type": "behavior_based_predictive_reminder",
  
  "time_intervals": {
    "daytime": {
      "name": "daytime",
      "start_hour": 6,
      "end_hour": 24,
      "interval_seconds": 3600,
      "interval_hours": 1,
      "description": "白天模式 (06:00-24:00) - 1小时提醒间隔",
      "enabled": true
    },
    "nighttime": {
      "name": "nighttime",
      "start_hour": 0,
      "end_hour": 6,
      "interval_seconds": 10800,
      "interval_hours": 3,
      "description": "深夜模式 (00:00-06:00) - 3小时提醒间隔",
      "enabled": true
    }
  },
  
  "chat_activity": {
    "active_threshold_seconds": 3600,
    "active_threshold_minutes": 60,
    "active_threshold_hours": 1,
    "description": "最后消息<1小时视为活跃聊天，暂停提醒",
    "enabled": true
  },
  
  "state_management": {
    "state_file": "heartbeat_state.json",
    "state_file_path": "/root/.openclaw/workspace/heartbeat_state.json",
    "auto_recovery": true,
    "backup_enabled": true,
    "max_backup_files": 10,
    "backup_interval_days": 7
  },
  
  "prediction_algorithm": {
    "algorithm": "time_based_prediction",
    "precision_seconds": 60,
    "adjust_for_timezone": true,
    "timezone": "Asia/Shanghai",
    "daylight_saving_support": false
  },
  
  "integration": {
    "openclaw_integration": {
      "enabled": true,
      "heartbeat_check_integration": true,
      "session_monitoring": true,
      "auto_start": true
    },
    "cron_integration": {
      "enabled": true,
      "check_interval_seconds": 60,
      "check_interval_minutes": 1,
      "log_enabled": true
    }
  },
  
  "logging": {
    "enabled": true,
    "log_dir": "logs",
    "log_level": "info",
    "log_to_memory": true,
    "memory_file_pattern": "memory/YYYY-MM-DD.md",
    "rotate_logs": true,
    "max_log_files": 30,
    "max_log_size_mb": 10
  },
  
  "performance": {
    "min_check_interval_seconds": 60,
    "max_prediction_time_seconds": 86400,
    "cache_enabled": true,
    "cache_ttl_seconds": 300
  },
  
  "safety": {
    "enable_backups": true,
    "user_confirmation_for_reset": false,
    "dry_run_mode": false,
    "emergency_reset_enabled": true
  },
  
  "notifications": {
    "reminder_notifications": {
      "enabled": true,
      "channels": ["feishu", "console"],
      "format": "predictive_reminder",
      "include_prediction": true
    },
    "error_notifications": {
      "enabled": true,
      "channels": ["console", "log_file"],
      "critical_only": true
    }
  },
  
  "monitoring": {
    "enable_monitoring": true,
    "metrics_collection": true,
    "prediction_accuracy_tracking": true,
    "performance_metrics": true,
    "health_check_enabled": true
  }
}